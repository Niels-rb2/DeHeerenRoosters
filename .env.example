# ─── Google OAuth (NextAuth) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=

# ─── Supabase (gedeeld met De Heeren - Kanban Board) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google Calendar API (info@cafedeheeren.nl agenda) ───────────────────────
# Service account JSON (base64) met domain-wide delegation of directe toegang
GOOGLE_CALENDAR_SA_JSON=
GOOGLE_CALENDAR_ID=info@cafedeheeren.nl

# ─── Web Push Notifications ──────────────────────────────────────────────────
# Genereer met: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@cafedeheeren.nl
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
